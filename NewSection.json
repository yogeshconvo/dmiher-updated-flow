{
    "section_id": "admission_steps",
    "data": {
        "title": "5 STEPS TO BEGIN YOUR JOURNEY",
        "background_image": "/assets/StepsPage.png",
        "note": "*Note - DMIHER-CET is exclusively conducted for the following streams: Engineering, Pharmacy, Physiotherapy, Nursing, Allied Health Sciences, and Allied Sciences programs.",
        "steps": [
            {
                "step": "Step 1",
                "title": "Explore Programs & Eligibility",
                "icon": "/assets/AdmissionGrid/Step1.png",
                "description": "270+ programs across Medicine, Dentistry, Nursing, and more",
                "linkText": "Check eligibility criteria",
                "href": "/programs",
                "note": "(12th pass with PCB/PCM or Diploma for respective programs)"
            },
            {
                "step": "Step 2",
                "title": "Register Online",
                "icon": "/assets/AdmissionGrid/Steps.png",
                "description": "Select your desired course and receive confirmation email.",
                "linkText": "Register",
                "href": "https://dmiher-apply.mastersofterp.com/ApplicationLandingPage/Index/DMIHER",
                "type": "external"
            },
            {
                "step": "Step 3",
                "title": "Fill the Application Form",
                "icon": "/assets/AdmissionGrid/Steps.png",
                "description": "Upload required documents (mark sheets, ID proof, etc).",
                "linkText": "Application form",
                "href": "https://dmiher-apply.mastersofterp.com/ApplicationLandingPage/Index/DMIHER",
                "type": "external"
            },
            {
                "step": "Step 4",
                "title": "Pay the Application Fee",
                "icon": "/assets/AdmissionGrid/Steps.png",
                "description": "Pay securely via Net Banking, Card, or UPI."
            },
            {
                "step": "Step 5",
                "title": "Entrance Exam / Counselling",
                "icon": "/assets/AdmissionGrid/Steps.png"
            },
            {
                "step": "",
                "title": "Confirm Admission",
                "icon": "/assets/AdmissionGrid/Complete.png",
                "description": "Receive provisional admission letter and secure your seat."
            }
        ]
    }
}


