# SPA + SSG routing for /dmiher-web/.
#
# Every HTML-shaped request (root, prerendered subroutes like /jnmc/, or
# arbitrary client-side routes like /college/page) must go through spa.php so:
#   - a fresh per-request CSP nonce is stamped into the served HTML
#   - spa.php picks the RIGHT file (prerendered home, prerendered subroute,
#     or the empty shell for SPA-only routes) based on REQUEST_URI
#
# Real static assets (JS, CSS, fonts, images, JSON, etc.) bypass spa.php and
# stream directly so the long-cache header below applies and PHP overhead
# stays off the hot path.
#
# Directory bypass note: `DirectoryIndex disabled` prevents Apache from
# auto-serving <subdir>/index.html for URLs like /dmiher-web/jnmc/. Without
# this, once a jnmc/index.html file exists on disk (from prerender), Apache
# would serve it raw — skipping spa.php's nonce stamping. The rewrite rule
# below sends every directory / non-asset request to spa.php, and spa.php
# reads REQUEST_URI to figure out which file to actually deliver.

DirectoryIndex disabled

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dmiher-web/

  # Real static assets served directly. Restricting the pass-through to a
  # known extension list means prerendered subdirs (which have no extension
  # in the URL) always fall through to the spa.php rule below.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule \.(?:js|mjs|css|map|json|xml|txt|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|svg|ico|php)$ - [L]

  # Everything else — root URL, prerendered subroutes, SPA client-side
  # routes, arbitrary paths — goes through the root spa.php wrapper.
  RewriteRule ^ spa.php [L]
</IfModule>

# Long-cache hashed assets; never cache HTML or the PHP wrapper.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "(index\.html|index\.shell\.html|spa\.php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
