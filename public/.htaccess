# SPA fallback for the /dmiher-web/ Apache subdirectory deployment.
# Any URL that doesn't map to a real file or directory under /dmiher-web/
# is rewritten to /dmiher-web/index.html so React Router can take over.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dmiher-web/

  # Don't rewrite real files or directories (assets, images, fonts, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls through to the SPA shell
  RewriteRule . index.html [L]
</IfModule>

# Long-cache hashed assets, never cache the HTML shell.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
